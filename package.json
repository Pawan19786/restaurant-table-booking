{
  "name": "tabletime",
  "version": "1.0.0",
  "description": "TableTime - Reservation Management System",
  "type": "module",
  "scripts": {
    "start": "node backend/Server.js",
    "backend": "cd backend && node Server.js",
    "backend:dev": "cd backend && nodemon Server.js",
    "dev": "start cmd /k \"cd backend && node Server.js\" && start cmd /k \"cd frontend && npm run dev\"",
    "frontend": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "setup": "cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.61",
    "@types/three": "^0.183.1",
    "cloudinary": "^2.9.0",
    "nodemailer": "^8.0.2",
    "three": "^0.183.2"
  }
}
